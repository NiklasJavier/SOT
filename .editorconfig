# EditorConfig - https://editorconfig.org
# Konsistente Code-Formatierung für alle Editoren
root = true

# =============================================================================
# Globale Einstellungen
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# =============================================================================
# Shell-Skripte
# =============================================================================
[*.sh]
indent_size = 4
shell_variant = bash
binary_next_line = true
switch_case_indent = true

# =============================================================================
# YAML-Dateien
# =============================================================================
[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# Jinja2-Templates
# =============================================================================
[*.j2]
indent_size = 2

# =============================================================================
# Markdown
# =============================================================================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# =============================================================================
# Makefiles (Tab-basiert)
# =============================================================================
[Makefile]
indent_style = tab
indent_size = 4

# =============================================================================
# Git-Konfiguration
# =============================================================================
[.gitignore]
indent_style = space
indent_size = 2

# =============================================================================
# JSON
# =============================================================================
[*.json]
indent_size = 2

# =============================================================================
# INI-Dateien (hosts.ini etc.)
# =============================================================================
[*.ini]
indent_size = 2

# =============================================================================
# Docker
# =============================================================================
[Dockerfile*]
indent_size = 4

[docker-compose*.yml]
indent_size = 2
