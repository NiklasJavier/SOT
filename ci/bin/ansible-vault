#!/usr/bin/env bash
set -euo pipefail
command=$1
shift || true
case "$command" in
  edit|view)
    echo "[ci] ansible-vault $command $*" >&2
    exit 0
    ;;
  encrypt|decrypt)
    echo "[ci] ansible-vault $command $*" >&2
    exit 0
    ;;
  *)
    echo "[ci] ansible-vault unsupported command: $command" >&2
    exit 0
    ;;
esac
